---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	canonical?: string;
}

const {
	title = "7.5 (nanatengo) | JAZZ FUNK SESSION BAND",
	description = "7.5（ナナテンゴ）は、大阪を拠点とするジャズ・ファンクセッショントリオ。Sax/Piano・Bass・Drumsの3人により構成。",
	ogImage = "/og-image.png",
	canonical = Astro.url.href,
} = Astro.props;

const siteUrl = "https://nanatengo.github.io/nanatengo/";

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "MusicGroup",
	name: "7.5 (nanatengo)",
	alternateName: "ナナテンゴ",
	url: siteUrl,
	description: description,
	genre: ["Jazz", "Funk", "Band"],
	numberOfMembers: 3,
	member: [
		{
			"@type": "Person",
			name: "Sakko",
			instrument: ["Saxophone", "Piano"],
		},
		{ "@type": "Person", name: "Takuro", instrument: "Bass Guitar" },
		{ "@type": "Person", name: "Gashiyama", instrument: "Drums" },
	],
	sameAs: [
		"https://www.instagram.com/nanatengo7.5_band/",
		"https://www.youtube.com/@nanatengo7.5_band",
	],
};
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />

		<!-- Primary Meta -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />

		<!-- OpenGraph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={`${siteUrl}${ogImage}`} />
		<meta property="og:locale" content="ja_JP" />
		<meta property="og:site_name" content="7.5 nanatengo" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body
		class="antialiased selection:bg-accent-orange selection:text-white relative"
	>
		<!-- SVG Filter for realistic brush/ink texture on strokes -->
		<svg
			style="visibility: hidden; position: absolute; width: 0; height: 0;"
			xmlns="http://www.w3.org/2000/svg"
		>
			<defs>
				<filter
					id="ink-bleed"
					x="-20%"
					y="-20%"
					width="140%"
					height="140%"
				>
					<!-- Generates cloudy noise -->
					<feTurbulence
						type="fractalNoise"
						baseFrequency="0.04"
						numOctaves="3"
						result="noise"></feTurbulence>
					<!-- Warps the source graphic using the noise, creating jagged rough edges -->
					<feDisplacementMap
						in="SourceGraphic"
						in2="noise"
						scale="20"
						xChannelSelector="R"
						yChannelSelector="G"
						result="warped"></feDisplacementMap>
					<!-- Blurs it slightly to look like bleeding ink -->
					<feGaussianBlur
						in="warped"
						stdDeviation="2"
						result="blurred"></feGaussianBlur>
				</filter>
			</defs>
		</svg>
		<!-- Decorative Background Strokes framing the edges -->
		<div
			class="fixed inset-0 pointer-events-none -z-10 overflow-hidden mix-blend-multiply opacity-80"
		>
			<!-- Left Edge -->
			<div class="absolute inset-y-0 left-0 w-[28vw]" data-speed="1.15">
				<!-- Top Left Group -->
				<div
					class="bg-stroke-blue"
					style="position: absolute; width: 120vw; height: 70px; transform: rotate(-35deg); top: -5%; left: -60vw;"
				>
				</div>
				<div
					class="bg-stroke-red"
					style="position: absolute; width: 100vw; height: 55px; transform: rotate(-35deg); top: 18%; left: -50vw;"
				>
				</div>
				<div
					class="bg-stroke-green"
					style="position: absolute; width: 110vw; height: 50px; transform: rotate(-35deg); top: 38%; left: -60vw;"
				>
				</div>
				<!-- Bottom Left Group -->
				<div
					class="bg-stroke-purple"
					style="position: absolute; width: 120vw; height: 45px; transform: rotate(45deg); bottom: 30%; left: -50vw;"
				>
				</div>
				<div
					class="bg-stroke-orange"
					style="position: absolute; width: 130vw; height: 40px; transform: rotate(42deg); bottom: 20%; left: -65vw;"
				>
				</div>
				<div
					class="bg-stroke-green"
					style="position: absolute; width: 130vw; height: 60px; transform: rotate(35deg); bottom: 0%; left: -65vw;"
				>
				</div>
			</div>

			<!-- Right Edge -->
			<div class="absolute inset-y-0 right-0 w-[28vw]" data-speed="0.85">
				<!-- Top Right Group -->
				<div
					class="bg-stroke-blue"
					style="position: absolute; width: 110vw; height: 40px; transform: rotate(35deg); top: 5%; right: -60vw;"
				>
				</div>
				<div
					class="bg-stroke-red"
					style="position: absolute; width: 120vw; height: 55px; transform: rotate(35deg); top: 20%; right: -50vw;"
				>
				</div>
				<!-- Bottom Right Group -->
				<div
					class="bg-stroke-blue"
					style="position: absolute; width: 140vw; height: 45px; transform: rotate(-40deg); bottom: 25%; right: -60vw;"
				>
				</div>
				<div
					class="bg-stroke-red"
					style="position: absolute; width: 140vw; height: 45px; transform: rotate(-38deg); bottom: 10%; right: -60vw;"
				>
				</div>
				<div
					class="bg-stroke-purple"
					style="position: absolute; width: 100vw; height: 65px; transform: rotate(-35deg); bottom: -5%; right: -50vw;"
				>
				</div>
			</div>
		</div>
		<slot />

		<script>
			// Parallax effect for background strokes without overriding CSS transforms
			// We animate wrapper divs instead of the individual lines
			document.addEventListener("scroll", () => {
				const scrollY = window.scrollY;
				const strokeGroups =
					document.querySelectorAll<HTMLElement>("[data-speed]");
				strokeGroups.forEach((group) => {
					const speed = parseFloat(
						group.getAttribute("data-speed") || "1",
					);
					const offset = scrollY * (speed - 1) * -0.2;
					group.style.transform = `translateY(${offset}px)`;
				});
			});
		</script>
	</body>
</html>
