---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
    const allNews = await getCollection('news');
    return allNews.map(entry => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const dateStr = entry.data.date.toISOString().split('T')[0].replace(/-/g, '.');

// SEO: Extract a plain-text description from the body
const rawBody = entry.body ?? '';
const plainText = rawBody.replace(/[#*`\[\]()>_-]/g, '').replace(/\n+/g, ' ').trim();
const description = plainText.slice(0, 120) + (plainText.length > 120 ? '…' : '');
const canonical = `${Astro.site ?? 'https://nanatengo.com'}/news/${entry.id}`;
---

<Layout
    title={`${entry.data.title} | 7.5 nanatengo`}
    description={description}
    canonical={canonical}
>
    <main class="w-full max-w-3xl mx-auto px-6 py-32 relative z-10 min-h-screen">
        <!-- Back link -->
        <nav aria-label="パンくずリスト">
            <a
                href="/#news"
                class="inline-flex items-center gap-2 text-sm font-bold tracking-widest uppercase text-primary/60 hover:text-accent-orange transition-colors mb-12 group"
            >
                <span class="inline-block group-hover:-translate-x-1 transition-transform">←</span>
                BACK TO NEWS
            </a>
        </nav>

        <!-- Article -->
        <article itemscope itemtype="https://schema.org/NewsArticle">
            <meta itemprop="publisher" content="7.5 nanatengo" />
            <time
                itemprop="datePublished"
                datetime={entry.data.date.toISOString()}
                class="font-bold text-accent-green tracking-widest text-sm uppercase block mb-4"
            >
                {dateStr}
            </time>
            <h1 itemprop="headline" class="font-heading text-5xl md:text-7xl text-primary mb-12 leading-tight">
                {entry.data.title}
            </h1>

            <!-- Divider -->
            <div class="h-[3px] w-24 bg-accent-orange rounded-full mb-12" role="separator" aria-hidden="true"></div>

            <!-- Article body -->
            <div
                itemprop="articleBody"
                class="prose prose-lg max-w-none text-primary/90 leading-relaxed space-y-6
                        [&>p]:text-lg [&>p]:leading-8
                        [&>h2]:font-heading [&>h2]:text-3xl [&>h2]:mt-10
                        [&>h3]:font-heading [&>h3]:text-2xl [&>h3]:mt-8
                        [&>a]:text-accent-orange [&>a]:underline"
            >
                <Content />
            </div>
        </article>

        <!-- Footer nav -->
        <footer class="mt-24 pt-8 border-t-2 border-primary/10">
            <a
                href="/#news"
                class="inline-flex items-center gap-3 bg-primary text-base px-8 py-4 rounded-full font-bold tracking-widest uppercase hover:bg-accent-orange transition-all duration-300 text-sm"
            >
                ← All News
            </a>
        </footer>
    </main>
</Layout>
