---
import { Image } from "astro:assets";
import artistImage from "../assets/artist.jpeg";
---

<section
    class="w-full max-w-5xl mx-auto px-6 py-24 flex flex-col items-center reveal-on-scroll"
>
    <div
        class="relative w-full aspect-square md:aspect-[16/9] overflow-hidden rounded-sm shadow-2xl border-[12px] border-base"
    >
        <!-- Using Astro Image for optimization -->
        <Image
            src={artistImage}
            alt="7.5 (nanatengo) band playing in studio"
            width={1200}
            height={1000}
            class="w-full h-full object-cover grayscale contrast-125 mix-blend-luminosity transition-transform duration-[2000ms] hover:scale-105"
        />
        <!-- Vintage overlays -->
        <div
            class="absolute inset-0 bg-accent-orange/15 mix-blend-color pointer-events-none"
        >
        </div>
        <div
            class="absolute inset-0 bg-primary/20 mix-blend-multiply pointer-events-none"
        >
        </div>
        <div
            class="absolute inset-0 ring-1 ring-inset ring-black/20 pointer-events-none"
        >
        </div>
    </div>
    <div class="mt-8 text-center max-w-2xl">
        <h3 class="font-heading text-4xl mb-4 text-primary">
            THREE PIECE JAZZ FUNK BAND
        </h3>
        <p class="opacity-80 leading-relaxed font-bold tracking-wider">
            3ピースのバンド♪♪♪<br />
            Funk,Jazz,Soul,Pops,etc.. <br />
            私たちなりにアレンジします！
        </p>
    </div>
</section>
