---
<section class="h-screen w-full flex flex-col items-center justify-center relative">
    <div class="text-center z-10 px-4 animate-fade-in opacity-0" style="animation-delay: 2.3s;">
        <h1 class="text-9xl md:text-[12rem] lg:text-[15rem] font-heading leading-none tracking-tighter text-primary mix-blend-multiply">
            7.5
            <span class="block text-4xl md:text-7xl text-accent-orange mt-[-1rem] md:mt-[-2rem] tracking-normal mix-blend-multiply">NANATENGO</span>
        </h1>
        <p class="mt-8 text-xl md:text-2xl font-bold tracking-widest uppercase text-primary/80">
            Jazz Funk Session Band
        </p>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center animate-fade-in opacity-0 cursor-pointer" style="animation-delay: 2.8s;" onclick="window.scrollTo({top: window.innerHeight, behavior: 'smooth'})">
        <span class="text-xs font-bold tracking-[0.3em] uppercase mb-3 text-primary/70">Scroll</span>
        <div class="w-[2px] h-16 bg-primary/70 origin-top animate-bounce-rhythmic"></div>
    </div>
</section>
