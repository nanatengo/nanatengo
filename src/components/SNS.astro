---

---

<section
    id="sns-contact"
    class="py-24 px-4 md:px-8 max-w-4xl mx-auto relative z-10 w-full text-center"
>
    <div class="mb-32 opacity-0 translate-y-10 reveal-on-scroll">
        <h2 class="text-4xl md:text-6xl font-heading mb-12 text-primary">
            LATEST SESSION
        </h2>
        <div
            class="relative w-full max-w-[320px] mx-auto aspect-[9/16] bg-primary/5 rounded-[2rem] overflow-hidden shadow-2xl border-4 border-base"
        >
            <!-- YouTube Shorts iframe lazy load -->
            <iframe
                class="absolute inset-0 w-full h-full"
                src="https://www.youtube.com/embed/9g9nik6f9z0"
                title="Cissy Strut / The Meters cover by 7.5 #shorts #cissystrut # #band #bandcover"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                loading="lazy"
                allowfullscreen
            >
            </iframe>
        </div>
    </div>

    <div class="opacity-0 translate-y-10 reveal-on-scroll delay-100">
        <h2 class="text-5xl md:text-7xl font-heading mb-16 text-primary">
            CONNECT
        </h2>

        <div class="flex justify-center gap-8 md:gap-16 mb-20">
            <a
                href="https://www.instagram.com/nanatengo7.5_band/"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagramで7.5 (nanatengo)をフォローする"
                class="group relative flex flex-col items-center"
            >
                <div
                    class="flex items-center justify-center w-24 h-24 md:w-32 md:h-32 bg-base border-2 border-primary rounded-full group-hover:bg-accent-orange group-hover:border-accent-orange group-hover:text-white transition-all duration-300 shadow-lg group-hover:shadow-accent-orange/50 group-hover:-translate-y-2 text-primary"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="48"
                        height="48"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="lucide lucide-instagram"
                        aria-hidden="true"
                        ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"
                        ></rect><path
                            d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                        ></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"
                        ></line></svg
                    >
                </div>
                <span
                    class="mt-4 font-bold tracking-widest text-xs md:text-sm uppercase text-primary/80 group-hover:text-accent-orange transition-colors"
                    >Instagram</span
                >
            </a>

            <a
                href="https://www.youtube.com/@nanatengo7.5_band"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="YouTubeで7.5 (nanatengo)の動画を視聴する"
                class="group relative flex flex-col items-center"
            >
                <div
                    class="flex items-center justify-center w-24 h-24 md:w-32 md:h-32 bg-base border-2 border-primary rounded-full group-hover:bg-primary group-hover:text-base transition-all duration-300 shadow-lg group-hover:shadow-primary/50 group-hover:-translate-y-2 text-primary"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="48"
                        height="48"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="lucide lucide-youtube"
                        aria-hidden="true"
                        ><path
                            d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"
                        ></path><path d="m10 15 5-3-5-3z"></path></svg
                    >
                </div>
                <span
                    class="mt-4 font-bold tracking-widest text-xs md:text-sm uppercase text-primary/80 group-hover:text-primary transition-colors"
                    >YouTube</span
                >
            </a>
        </div>

        <div
            class="bg-white/40 backdrop-blur-md p-8 md:p-12 rounded-3xl border border-primary/10 shadow-xl max-w-2xl mx-auto"
        >
            <h3 class="text-3xl font-heading mb-2 text-primary">
                BOOKING & INQUIRY
            </h3>
            <p
                class="mb-8 font-bold text-primary/60 tracking-widest text-sm uppercase"
            >
                お問合せはインスタのDMまで
            </p>
            <a
                href="https://www.instagram.com/nanatengo7.5_band/"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram DMでお問い合わせを送る"
                class="inline-flex items-center justify-center gap-3 bg-primary text-base px-10 py-5 rounded-full font-bold tracking-widest uppercase hover:bg-accent-orange hover:text-white transition-all duration-300 shadow-lg hover:shadow-2xl transform hover:-translate-y-1"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-instagram"
                    aria-hidden="true"
                    ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"
                    ></rect><path
                        d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                    ></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"
                    ></line></svg
                >
                Send a Message
            </a>
        </div>
    </div>
</section>
