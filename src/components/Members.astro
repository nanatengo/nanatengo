---
import { Image } from 'astro:assets';
import sakkoImg from '../assets/sakko.jpeg';
import takuroImg from '../assets/takuro.jpeg';
import gashiyamaImg from '../assets/gashiyama.jpeg';

const members = [
    {
        name: "Sakko",
        role: "Sax / Piano",
        bio: "",
        accentColor: "rgba(228, 87, 46, 0.4)", // orange
        image: sakkoImg
    },
    {
        name: "Takuro",
        role: "Bass",
        bio: "",
        accentColor: "rgba(58, 141, 93, 0.4)", // green
        image: takuroImg
    },
    {
        name: "Gashiyama",
        role: "Drums",
        bio: "",
        accentColor: "rgba(107, 63, 160, 0.4)", // purple
        image: gashiyamaImg
    }
];
---
<section id="members" class="py-24 px-4 md:px-8 max-w-6xl mx-auto w-full relative z-10 min-h-[80vh]">
    <h2 class="text-6xl md:text-8xl font-heading mb-20 text-center text-primary opacity-0 translate-y-10 reveal-on-scroll">
        MEMBERS
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-24 md:gap-8">
        {members.map((member, index) => (
            <div class="flex flex-col items-center group opacity-0 translate-y-10 reveal-on-scroll" style={`transition-delay: ${index * 150}ms;`}>
                <div class="relative w-full max-w-[280px] aspect-[4/5] mb-8">
                    <!-- Custom inline blur for stroke -->
                    <div 
                        class="absolute inset-0 left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[140%] h-[140%] opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none rounded-full blur-[40px]" 
                        style={`background: radial-gradient(circle, ${member.accentColor} 0%, transparent 70%);`}
                    ></div>
                    
                    <!-- Fixed background stroke -->
                    <div class="absolute -inset-4 bg-primary/5 -z-10 rounded-3xl transform rotate-3 group-hover:rotate-0 transition-transform duration-500"></div>

                    <!-- Member Photo -->
                    <div class="w-full h-full overflow-hidden rounded-2xl relative z-10 shadow-xl group-hover:scale-[1.02] transition-transform duration-500">
                        <Image 
                            src={member.image} 
                            alt={`${member.name} - ${member.role}`}
                            width={1200}
                            height={1000}
                            class="w-full h-full object-cover filter grayscale sepia-[0.3] contrast-125 group-hover:grayscale-0 transition-all duration-700"
                            loading="lazy"
                        />
                    </div>
                </div>
                <h3 class="text-4xl font-heading text-primary relative z-10 bg-base backdrop-blur-md px-4 pt-2 -mt-16 rounded-t-xl">{member.name}</h3>
                <p class="text-sm font-bold tracking-[0.2em] text-primary/70 uppercase mt-2 relative z-10">{member.role}</p>
                {/* <p class="text-sm text-primary/60 leading-relaxed mt-3 text-center max-w-[240px]">{member.bio}</p> */}
            </div>
        ))}
    </div>
</section>
